{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "strict": true,
    
    "typeRoots": [
      "./node_modules/@types", 
      "./src/@types"
    ],
    
    "types": ["jest"],
    "sourceMap": true,
    "declaration": true,
    "skipLibCheck": true,
     "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,


    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  }
}
